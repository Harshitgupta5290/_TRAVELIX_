# ============================================
# TRAVELIX — Environment Variables
# ============================================
# Uses Neon PostgreSQL for BOTH local dev and production.
# Get your free database at https://neon.tech
#
# 1. Create a Neon project
# 2. Copy the connection string
# 3. Paste it as DATABASE_URL below

DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
NEXTAUTH_SECRET="any-random-string-change-in-production"

# Run after setting DATABASE_URL:
#   npm run db:push
#   npm run db:seed
