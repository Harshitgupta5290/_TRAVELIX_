# ============================================
# TRAVELIX — Environment Variables
# ============================================

# Required locally (.env and .env.local):
DATABASE_URL="file:./prisma/dev.db"
NEXTAUTH_SECRET="any-random-string-change-in-production"

# Required on Vercel only:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"   ← Neon URL
# NEXTAUTH_SECRET="run: openssl rand -base64 32"
# NEXTAUTH_URL="https://your-app.vercel.app"
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
