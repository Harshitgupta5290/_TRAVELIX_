# ============================================
# TRAVELIX — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
# Also create a .env file with just DATABASE_URL so Prisma CLI can read it.

# ----- Database -----
# Local development (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# Production — Neon PostgreSQL (recommended for Vercel):
# 1. Create free account at https://neon.tech
# 2. Create a project, copy the connection string
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
#
# Other PostgreSQL options: Supabase, PlanetScale, Railway

# ----- NextAuth -----
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret-in-production"

# Local development:
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel): set this to your deployment URL
# NEXTAUTH_URL="https://your-app.vercel.app"

# ----- App Config -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TRAVELIX"
